{
  "manifest_version": 3,
  "name": "YT Insights",
  "version": "2.0.0",
  "description": "Industrial-grade YouTube comment sentiment analysis — powered by AI.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "YT Insights",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "activeTab",
    "tabs"
  ],

  "host_permissions": [
    "https://www.googleapis.com/youtube/v3/*",
    "http://23.20.221.231:8080/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "minimum_chrome_version": "102"
}
