{
  "manifest_version": 3,
  "name": "YouTube Sentiment Insights",
  "version": "1.0",
  "description": "Analyzes YouTube video comments for sentiment.",
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/sentiment_arnab.png"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "http://localhost:8080/*",
    "https://www.googleapis.com/*"
  ]
}